<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.sams.controller.MarkAttendanceController" spacing="15">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    
    <Label text="Mark Attendance" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Select Class:"/>
        <ComboBox fx:id="classComboBox" prefWidth="300"/>
        <Button text="Load Students" onAction="#loadStudentsForClass"/>
    </HBox>
    
    <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colRegNo" text="Reg No" prefWidth="150"/>
            <TableColumn fx:id="colName" text="Student Name" prefWidth="200"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
            <TableColumn fx:id="colRemarks" text="Remarks" prefWidth="200"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Save Attendance" onAction="#handleSaveAttendance" style="-fx-font-weight: bold;"/>
    </HBox>
</VBox>
