<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sams.controller.LoginController"
           prefHeight="600.0" prefWidth="800.0">
    <VBox alignment="CENTER" spacing="15" maxWidth="300">
        <Label text="SAMS Login" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <TextField fx:id="usernameField" promptText="Username"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>
        <Button text="Login" onAction="#handleLogin" prefWidth="300" style="-fx-font-weight: bold;"/>
        <Label fx:id="errorLabel" textFill="red" visible="false"/>
    </VBox>
</StackPane>
